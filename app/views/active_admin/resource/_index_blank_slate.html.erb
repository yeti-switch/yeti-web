<%# Overrides ActiveAdmin 4's partial. Keep in sync with the gem on upgrade.
    Adds back two options the old ActiveAdmin::Views::Pages::Index#render_blank_slate
    supported and that app/admin still uses:
      blank_slate_content:      -> proc rendering custom content (active_calls,
                                   outgoing_registrations)
      disable_blank_slate_link: -> true suppresses the "create one" link
                                   (cnam_databases, lnp_databases) %>
<div class="w-full rounded-lg border-2 border-dashed border-gray-300 hover:border-gray-400 dark:border-gray-700 dark:hover:border-gray-600 px-6 py-12 text-center">
  <h2 class="block mb-4 only:mb-0 font-semibold leading-6 text-gray-900 dark:text-gray-200">
    <% content = page_presenter.options[:blank_slate_content] %>
    <% content = instance_exec(&content) if content.is_a?(Proc) %>
    <%= content || I18n.t("active_admin.blank_slate.content", resource_name: active_admin_config.plural_resource_label) %>
  </h2>
  <% unless page_presenter.options[:disable_blank_slate_link] %>
    <% if new_action_authorized?(active_admin_config.resource_class) %>
      <%= if page_presenter.options.has_key?(:blank_slate_link)
            link = page_presenter.options[:blank_slate_link]
            instance_exec(&link) if link.is_a?(Proc)
          else
            link_to(I18n.t("active_admin.blank_slate.link"), new_resource_path)
          end
      %>
    <% end %>
  <% end %>
</div>
