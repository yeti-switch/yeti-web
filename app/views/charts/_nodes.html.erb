<script type="text/javascript">
  $(document).ready(function () {
    // .off before .on so re-running this script (e.g. from a tab re-render)
    // doesn't stack handlers and trigger the fetch multiple times per click.
    $(".tabs [data-tab-target='#<%= href %>']").off('click.nodesChart').on('click.nodesChart', function () {
      Charts.renderRanged({
        url: "/remote_stats/<%= path %>.json",
        canvasId: 'nodes-chart',
        placeholderId: 'chart-placeholder-nodes',
        type: 'stackedArea',
        chartOpts: { yTickPrecision: 'integer' }
      });
    });
    $(".tabs [data-tab-target='#<%= href %>']").trigger('click.nodesChart');
  });
</script>
<div id="chart-placeholder-nodes" class="chart-placeholder chart-container">
  <canvas id="nodes-chart" class="stat-chart"></canvas>
</div>
