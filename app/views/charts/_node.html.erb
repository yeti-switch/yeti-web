<div id="chart-placeholder-node"
     class="chart-placeholder chart-container js-chart"
     data-chart-render="ranged"
     data-chart-tab="#active-calls-chart"
     data-chart-url="/remote_stats/<%= params[:id] %>/node.json"
     data-chart-canvas="node-chart"
     data-chart-type="line"
     data-chart-y-label="Active Calls"
     data-chart-y-precision="integer">
  <canvas id="node-chart" class="stat-chart"></canvas>
</div>
