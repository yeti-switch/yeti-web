<script type="text/javascript">
  $(document).ready(function () {
    $(".tabs [data-tab-target='#charts']").on("click", function () {
      Charts.renderRanged({
        url: "/remote_stats/<%= params[:id] %>/term_gateway.json",
        canvasId: 'term-gw-chart',
        placeholderId: 'chart-placeholder-term-gw',
        type: 'line',
        chartOpts: { yAxisLabel: 'Active Calls', yTickPrecision: 'integer' }
      });
    });
  });
</script>
<div id="chart-placeholder-term-gw" class="chart-placeholder chart-container">
  <canvas id="term-gw-chart" class="stat-chart"></canvas>
</div>
