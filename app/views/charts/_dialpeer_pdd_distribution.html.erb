<script type="text/javascript">
  $(document).ready(function () {
    $("div.tabs a[href='#termination-chart']").on("click", function () {
      $.getJSON("/remote_stats/<%= params[:id] %>/dialpeer_pdd_distribution.json", function (json) {
        Charts.renderBar('dialpeer-pdd-chart', json, {
          placeholderId: 'chart-placeholder-account',
          xAxisLabel: 'PDD (seconds)',
          yAxisLabel: 'Count',
          xScale: 'category',
          yTickPrecision: 'integer'
        });
      });
    });
  });
</script>
<div id="chart-placeholder-account" class="chart-placeholder chart-container">
  <canvas id="dialpeer-pdd-chart" class="stat-chart"></canvas>
</div>
