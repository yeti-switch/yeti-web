#!/usr/bin/env ruby
# frozen_string_literal: true

# Extracts one or more SQL function definitions from a structure.sql file.
#
# Usage:
#   bin/extract_function <schema.function_name> [sql_file]
#   bin/extract_function switch22.route
#   bin/extract_function switch22.process_gw db/structure.sql
#   bin/extract_function switch22.route db/structure.sql > /tmp/route.sql
#
# If the function is overloaded (multiple signatures), all overloads are printed.
# The leading "CREATE FUNCTION" is rewritten to "CREATE OR REPLACE FUNCTION".

func_name = ARGV[0]
sql_file  = ARGV[1] || File.join(__dir__, '..', 'db', 'structure.sql')

if func_name.nil?
  warn "Usage: #{File.basename($PROGRAM_NAME)} <schema.function_name> [sql_file]"
  warn "Example: #{File.basename($PROGRAM_NAME)} switch22.route"
  exit 1
end

unless File.exist?(sql_file)
  warn "File not found: #{sql_file}"
  exit 1
end

def detect_delimiter(line)
  Regexp.escape(Regexp.last_match(1)) if line =~ /\bAS\s+(\$[^$]*\$)\s*$/i
end

# Collects all lines of one function body starting at lines[start_idx].
# Returns [buf, next_i] where next_i is the index after the closing delimiter.
def collect_function(lines, start_idx)
  buf       = []
  delimiter = nil
  i         = start_idx

  while i < lines.length
    buf << lines[i]
    delimiter = detect_delimiter(buf.last) if delimiter.nil?
    if delimiter && lines[i].strip =~ /\A#{delimiter};\z/
      return [buf, i + 1]
    end

    i += 1
  end

  [buf, i]
end

# Matches the start of any CREATE [OR REPLACE] FUNCTION <name>(
start_re = /\ACREATE (?:OR REPLACE |or replace )?FUNCTION\s+#{Regexp.escape(func_name)}\s*\(/i

lines     = File.readlines(sql_file)
results   = [] # array of extracted function strings
i         = 0

while i < lines.length
  line = lines[i]

  if line.match?(start_re)
    buf, i = collect_function(lines, i)
    buf[0] = buf[0].sub(/\ACREATE FUNCTION/i, 'CREATE OR REPLACE FUNCTION')
    results << buf.join
    next # i already advanced inside collect_function
  end

  i += 1
end

if results.empty?
  warn "Function '#{func_name}' not found in #{sql_file}"
  exit 1
end

results.each_with_index do |fn, idx|
  puts fn
  puts unless idx == results.length - 1
end
